exports[`prettier-ignore.xaml 1`] = `
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <!-- This element should be formatted normally -->
        <TextBlock Text="Formatted text"    Margin="10,5"   FontSize="14" />

        <!-- prettier-ignore -->
        <TextBox  Text="This should NOT be formatted"   Width="200"    Height="30"    Background="Red"/>

        <!-- This should be formatted again -->
        <Button Content="Formatted button" Margin="10" Padding="5,2" />

        <!-- prettier-ignore -->
        <Border BorderBrush="Blue"   BorderThickness="2">
            <Label Content="Ignored formatting"    FontWeight="Bold"/>
        </Border>

        <!-- Normal formatting resumes -->
        <CheckBox Content="Normal checkbox" IsChecked="True" />
    </StackPanel>

</Window>
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
<Window
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>

  <StackPanel>
    <!-- This element should be formatted normally -->
    <TextBlock Text="Formatted text" Margin="10,5" FontSize="14" />

    <!-- prettier-ignore -->
    <TextBox  Text="This should NOT be formatted"   Width="200"    Height="30"    Background="Red"/>

    <!-- This should be formatted again -->
    <Button Content="Formatted button" Margin="10" Padding="5,2" />

    <!-- prettier-ignore -->
    <Border BorderBrush="Blue"   BorderThickness="2">
            <Label Content="Ignored formatting"    FontWeight="Bold"/>
        </Border>

    <!-- Normal formatting resumes -->
    <CheckBox Content="Normal checkbox" IsChecked="True" />
  </StackPanel>

</Window>

`;

exports[`self-closing-ignore.xaml 1`] = `
<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <!-- Normal formatting -->
    <TextBlock Text="Normal" Margin="5" />

    <!-- prettier-ignore -->
    <Button   Content="Ignored"   Width="100"    Height="50"  />

    <!-- Another normal element -->
    <Label Content="Normal again" />
</Grid>
