// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`example.xaml 1`] = `
<Window x:Class="SampleApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SampleApp.Views"
        xmlns:vm="clr-namespace:SampleApp.ViewModels"
        xmlns:controls="clr-namespace:SampleApp.Controls"
        xmlns:converters="clr-namespace:SampleApp.Converters"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="Sample Application"
        Width="1024"
        Height="768"
        mc:Ignorable="d">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="boolToVis" />
        <converters:InverseBooleanConverter x:Key="inverseBool" />


        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10,10,10,10" DontWrapThisAttr="This is a very long attribute with lots of words that shouldn't be wrapped by word" class="This is a class attribute that should be wrapped per word because its a class though its probably not relevant to xaml files since its not html">
        <!-- Main Layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0 0 0 10">
            <TextBlock Text="Dashboard"
                       Style="{StaticResource HeaderTextStyle}"/>
            <Button Content="Refresh"
                    Command="{Binding RefreshCommand}"
                    Margin="20 0 0 0"/>
            <Button Content="Save Changes"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding HasUnsavedChanges}"
                    Margin="10 0 0 0"/>
        </StackPanel>

        <!-- Main Content Area -->
        <TabControl Grid.Row="1">

            <!-- Overview Tab -->
            <TabItem Header=" Overview ">
                <Grid>
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="2*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Summary Panel -->
                        <controls:SummaryPanel
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            DataContext="{Binding SummaryData}"
                            Margin="0,0,0,20"/>

                        <!-- Statistics List -->
                        <ListBox Grid.Row="1"
                                 Grid.Column="0"
                                 ItemsSource="{Binding Statistics}"
                                 SelectedItem="{Binding SelectedStatistic}"
                                 Margin="0,0,10,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text=": " />
                                        <TextBlock Text="{Binding Value}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Chart Display -->
                        <controls:ChartControl
                            Grid.Row="1"
                            Grid.Column="1"
                            DataContext="{Binding ChartViewModel}"
                            ChartType="{x:Static controls:ChartType.LineChart}"
                            SeriesData="{Binding TimeSeriesData}"
                            Margin="10,0,0,0"/>

                        <!-- Details Grid -->
                        <DataGrid Grid.Row="2"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  ItemsSource="{Binding DetailedItems}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  Margin="0,20,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header=" Settings ">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <GroupBox Header="General Settings" Margin="0,0,0,20">
                            <StackPanel Margin="10">
                                <CheckBox Content="Enable automatic updates"
                                          IsChecked="{Binding Settings.AutoUpdate}"/>
                                <CheckBox Content="Show notifications"
                                          IsChecked="{Binding Settings.ShowNotifications}"
                                          Margin="0,10,0,0"/>
                                <CheckBox Content="Dark mode"
                                          IsChecked="{Binding Settings.DarkMode}"
                                          Margin="0,10,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Advanced Options" Margin="0,0,0,20">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Cache Size:" Margin="0,0,10,10"/>
                                <Slider Grid.Row="0" Grid.Column="1"
                                        Minimum="100"
                                        Maximum="10000"
                                        Value="{Binding Settings.CacheSize}"
                                        Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Timeout (ms):" Margin="0,0,10,10"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding Settings.TimeoutMilliseconds}"
                                         Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Log Level:" Margin="0,0,10,0"/>
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          SelectedItem="{Binding Settings.LogLevel}"
                                          ItemsSource="{Binding AvailableLogLevels}"/>
                            </Grid>
                        </GroupBox>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Reset to Defaults"
                                    Command="{Binding ResetSettingsCommand}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Apply"
                                    Command="{Binding ApplySettingsCommand}"
                                    IsEnabled="{Binding Settings.HasChanges}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Data Management Tab -->
            <TabItem Header=" Data ">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <ToolBar Grid.Row="0">
                        <Button Content="Import" Command="{Binding ImportDataCommand}"/>
                        <Button Content="Export" Command="{Binding ExportDataCommand}"/>
                        <Separator/>
                        <Button Content="Delete Selected"
                                Command="{Binding DeleteSelectedCommand}"
                                IsEnabled="{Binding HasSelectedItems}"/>
                    </ToolBar>

                    <!-- Data View -->
                    <controls:DataGridView Grid.Row="1"
                                           DataContext="{Binding DataGridViewModel}"
                                           ItemsSource="{Binding FilteredData}"
                                           SelectedItems="{Binding SelectedItems}"
                                           SortDescriptions="{Binding SortDescriptions}"
                                           FilterText="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Items: "/>
                    <TextBlock Text="{Binding ItemCount}"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="100"
                             Height="16"
                             Value="{Binding ProgressValue}"
                             Visibility="{Binding IsLoading, Converter={StaticResource boolToVis}}"/>
							 <TextBlock Text="OK" Visibility="{Binding IsLoading, Converter={StaticResource inverseBool}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
<Window
  x:Class="SampleApp.Views.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:SampleApp.Views"
  xmlns:vm="clr-namespace:SampleApp.ViewModels"
  xmlns:controls="clr-namespace:SampleApp.Controls"
  xmlns:converters="clr-namespace:SampleApp.Converters"
  d:DataContext="{d:DesignInstance vm:MainViewModel}"
  Title="Sample Application"
  Width="1024"
  Height="768"
  mc:Ignorable="d"
>

  <Window.Resources>
    <converters:BooleanToVisibilityConverter x:Key="boolToVis" />
    <converters:InverseBooleanConverter x:Key="inverseBool" />

    <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
  </Window.Resources>

  <Grid
    Margin="10,10,10,10"
    DontWrapThisAttr="This is a very long attribute with lots of words that shouldn't be wrapped by word"
    class="
      This
      is
      a
      class
      attribute
      that
      should
      be
      wrapped
      per
      word
      because
      its
      a
      class
      though
      its
      probably
      not
      relevant
      to
      xaml
      files
      since
      its
      not
      html
    "
  >
    <!-- Main Layout -->
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header Section -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 10">
      <TextBlock Text="Dashboard" Style="{StaticResource HeaderTextStyle}" />
      <Button
        Content="Refresh"
        Command="{Binding RefreshCommand}"
        Margin="20 0 0 0"
      />
      <Button
        Content="Save Changes"
        Command="{Binding SaveCommand}"
        IsEnabled="{Binding HasUnsavedChanges}"
        Margin="10 0 0 0"
      />
    </StackPanel>

    <!-- Main Content Area -->
    <TabControl Grid.Row="1">

      <!-- Overview Tab -->
      <TabItem Header=" Overview ">
        <Grid>
          <Grid Margin="15">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="2*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Summary Panel -->
            <controls:SummaryPanel
              Grid.Row="0"
              Grid.Column="0"
              Grid.ColumnSpan="2"
              DataContext="{Binding SummaryData}"
              Margin="0,0,0,20"
            />

            <!-- Statistics List -->
            <ListBox
              Grid.Row="1"
              Grid.Column="0"
              ItemsSource="{Binding Statistics}"
              SelectedItem="{Binding SelectedStatistic}"
              Margin="0,0,10,0"
            >
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                    <TextBlock Text=": " />
                    <TextBlock Text="{Binding Value}" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <!-- Chart Display -->
            <controls:ChartControl
              Grid.Row="1"
              Grid.Column="1"
              DataContext="{Binding ChartViewModel}"
              ChartType="{x:Static controls:ChartType.LineChart}"
              SeriesData="{Binding TimeSeriesData}"
              Margin="10,0,0,0"
            />

            <!-- Details Grid -->
            <DataGrid
              Grid.Row="2"
              Grid.Column="0"
              Grid.ColumnSpan="2"
              ItemsSource="{Binding DetailedItems}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              Margin="0,20,0,0"
            >
              <DataGrid.Columns>
                <DataGridTextColumn
                  Header="ID"
                  Binding="{Binding Id}"
                  Width="80"
                />
                <DataGridTextColumn
                  Header="Name"
                  Binding="{Binding Name}"
                  Width="*"
                />
                <DataGridTextColumn
                  Header="Status"
                  Binding="{Binding Status}"
                  Width="120"
                />
                <DataGridCheckBoxColumn
                  Header="Active"
                  Binding="{Binding IsActive}"
                  Width="80"
                />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Grid>
      </TabItem>

      <!-- Settings Tab -->
      <TabItem Header=" Settings ">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="20">
            <GroupBox Header="General Settings" Margin="0,0,0,20">
              <StackPanel Margin="10">
                <CheckBox
                  Content="Enable automatic updates"
                  IsChecked="{Binding Settings.AutoUpdate}"
                />
                <CheckBox
                  Content="Show notifications"
                  IsChecked="{Binding Settings.ShowNotifications}"
                  Margin="0,10,0,0"
                />
                <CheckBox
                  Content="Dark mode"
                  IsChecked="{Binding Settings.DarkMode}"
                  Margin="0,10,0,0"
                />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Advanced Options" Margin="0,0,0,20">
              <Grid Margin="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                  Grid.Row="0"
                  Grid.Column="0"
                  Text="Cache Size:"
                  Margin="0,0,10,10"
                />
                <Slider
                  Grid.Row="0"
                  Grid.Column="1"
                  Minimum="100"
                  Maximum="10000"
                  Value="{Binding Settings.CacheSize}"
                  Margin="0,0,0,10"
                />

                <TextBlock
                  Grid.Row="1"
                  Grid.Column="0"
                  Text="Timeout (ms):"
                  Margin="0,0,10,10"
                />
                <TextBox
                  Grid.Row="1"
                  Grid.Column="1"
                  Text="{Binding Settings.TimeoutMilliseconds}"
                  Margin="0,0,0,10"
                />

                <TextBlock
                  Grid.Row="2"
                  Grid.Column="0"
                  Text="Log Level:"
                  Margin="0,0,10,0"
                />
                <ComboBox
                  Grid.Row="2"
                  Grid.Column="1"
                  SelectedItem="{Binding Settings.LogLevel}"
                  ItemsSource="{Binding AvailableLogLevels}"
                />
              </Grid>
            </GroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button
                Content="Reset to Defaults"
                Command="{Binding ResetSettingsCommand}"
                Margin="0,0,10,0"
              />
              <Button
                Content="Apply"
                Command="{Binding ApplySettingsCommand}"
                IsEnabled="{Binding Settings.HasChanges}"
              />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Data Management Tab -->
      <TabItem Header=" Data ">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Toolbar -->
          <ToolBar Grid.Row="0">
            <Button Content="Import" Command="{Binding ImportDataCommand}" />
            <Button Content="Export" Command="{Binding ExportDataCommand}" />
            <Separator />
            <Button
              Content="Delete Selected"
              Command="{Binding DeleteSelectedCommand}"
              IsEnabled="{Binding HasSelectedItems}"
            />
          </ToolBar>

          <!-- Data View -->
          <controls:DataGridView
            Grid.Row="1"
            DataContext="{Binding DataGridViewModel}"
            ItemsSource="{Binding FilteredData}"
            SelectedItems="{Binding SelectedItems}"
            SortDescriptions="{Binding SortDescriptions}"
            FilterText="{Binding
              FilterText,
              UpdateSourceTrigger=PropertyChanged
            }"
          />
        </Grid>
      </TabItem>
    </TabControl>

    <!-- Status Bar -->
    <StatusBar Grid.Row="2">
      <StatusBarItem>
        <TextBlock Text="{Binding StatusMessage}" />
      </StatusBarItem>
      <Separator />
      <StatusBarItem>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="Items: " />
          <TextBlock Text="{Binding ItemCount}" />
        </StackPanel>
      </StatusBarItem>
      <StatusBarItem HorizontalAlignment="Right">
        <ProgressBar
          Width="100"
          Height="16"
          Value="{Binding ProgressValue}"
          Visibility="{Binding IsLoading, Converter={StaticResource boolToVis}}"
        />
        <TextBlock
          Text="OK"
          Visibility="{Binding
            IsLoading,
            Converter={StaticResource inverseBool}
          }"
        />
      </StatusBarItem>
    </StatusBar>
  </Grid>
</Window>

`;
