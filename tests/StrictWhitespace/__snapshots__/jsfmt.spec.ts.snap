// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`adjacent-elements.xaml 1`] = `
<Outer>
  <Foo
  /><Bar
  /><Baz />
</Outer>
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
<Outer>
  <Foo /><Bar /><Baz />
</Outer>

`;

exports[`comprehensive-test.xaml 1`] = `
<Root>
  <!-- Test 1: Adjacent self-closing elements -->
  <Foo /><Bar /><Baz />

  <!-- Test 2: Mix of self-closing and regular elements -->
  <First />
  <Second>Content</Second><Third />

  <!-- Test 3: Elements with text content between them (should have normal spacing) -->
  <Text>Some text</Text>
  More text here
  <AnotherText>More content</AnotherText>

  <!-- Test 4: Nested adjacent elements -->
  <Container><Child1 /><Child2 /></Container>

  <!-- Test 5: TextBlock example from user's description -->
  <TextBlock>
    <Run Text="Something (" /><Run Text="{Binding Foo}" /><Run Text=")" />
  </TextBlock>
</Root>
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
<Root>
  <!-- Test 1: Adjacent self-closing elements -->
  <Foo /><Bar /><Baz />

  <!-- Test 2: Mix of self-closing and regular elements -->
  <First />
  <Second>
    Content
  </Second><Third />

  <!-- Test 3: Elements with text content between them (should have normal spacing) -->
  <Text>
    Some text
  </Text>
  More text here
  <AnotherText>
    More content
  </AnotherText>

  <!-- Test 4: Nested adjacent elements -->
  <Container>
    <Child1 /><Child2 />
  </Container>

  <!-- Test 5: TextBlock example from user's description -->
  <TextBlock>
    <Run Text="Something (" /><Run Text="{Binding Foo}" /><Run Text=")" />
  </TextBlock>
</Root>

`;

exports[`mixed-length-runs.xaml 1`] = `
<TextBlock>
    <Run Text="Short" /><Run Text="This is a very long text attribute that should definitely cause wrapping because it exceeds reasonable line length limits and should force all adjacent elements to wrap consistently" /><Run Text="Short2" />
</TextBlock>
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
<TextBlock>
  <Run
    Text="Short"
  /><Run
    Text="This is a very long text attribute that should definitely cause wrapping because it exceeds reasonable line length limits and should force all adjacent elements to wrap consistently"
  /><Run
    Text="Short2"
  />
</TextBlock>

`;

exports[`textblock-runs.xaml 1`] = `
<Window>
    <TextBlock>
        <Run Text="Maximum Weight (" /><Run Text="{Binding WeightUnitLabel, Mode=OneWay}" /><Run Text=")" />
    </TextBlock>
</Window>
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
<Window>
  <TextBlock>
    <Run Text="Maximum Weight (" /><Run
      Text="{Binding WeightUnitLabel, Mode=OneWay}"
    /><Run Text=")" />
  </TextBlock>
</Window>

`;

exports[`wide-adjacent-elements.xaml 1`] = `
<Root>
  <!-- Test with very long attribute values that should force wrapping -->
  <VeryLongElementNameThatShouldForceWrapping SomeVeryLongAttributeName="This is a very long attribute value that should definitely cause the formatter to wrap the line because it exceeds reasonable line length limits" /><AnotherVeryLongElementNameThatShouldAlsoForceWrapping AnotherVeryLongAttributeName="Another extremely long attribute value that will make this line way too long to fit on a single line in most reasonable formatting scenarios" />

  <!-- Test with multiple adjacent elements with long attributes -->
  <FirstElement VeryLongAttribute="This attribute value is intentionally very long to force line wrapping behavior in the prettier formatter" /><SecondElement AnotherLongAttribute="This is another long attribute that should cause wrapping" /><ThirdElement YetAnotherLongAttribute="And this is a third long attribute value" />

  <!-- Test with nested elements that have long content -->
  <ContainerWithVeryLongNameThatExceedsReasonableLineLengths>
    <ChildElementWithLongName AttributeWithVeryLongName="Long attribute value here" /><AnotherChildElementWithLongName AnotherAttributeWithVeryLongName="Another long attribute value that should cause wrapping" />
  </ContainerWithVeryLongNameThatExceedsReasonableLineLengths>

  <!-- Test with nested non-self-closing elements that have long content -->
  <ContainerWithVeryLongNameThatExceedsReasonableLineLengths>
    <ChildElementWithLongName AttributeWithVeryLongName="Long attribute value here">Foo bar baz</ChildElementWithLongName><AnotherChildElementWithLongName AnotherAttributeWithVeryLongName="Another long attribute value that should cause wrapping">More content here</AnotherChildElementWithLongName>
  </ContainerWithVeryLongNameThatExceedsReasonableLineLengths>
</Root>
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
<Root>
  <!-- Test with very long attribute values that should force wrapping -->
  <VeryLongElementNameThatShouldForceWrapping
    SomeVeryLongAttributeName="This is a very long attribute value that should definitely cause the formatter to wrap the line because it exceeds reasonable line length limits"
  /><AnotherVeryLongElementNameThatShouldAlsoForceWrapping
    AnotherVeryLongAttributeName="Another extremely long attribute value that will make this line way too long to fit on a single line in most reasonable formatting scenarios"
  />

  <!-- Test with multiple adjacent elements with long attributes -->
  <FirstElement
    VeryLongAttribute="This attribute value is intentionally very long to force line wrapping behavior in the prettier formatter"
  /><SecondElement
    AnotherLongAttribute="This is another long attribute that should cause wrapping"
  /><ThirdElement
    YetAnotherLongAttribute="And this is a third long attribute value"
  />

  <!-- Test with nested elements that have long content -->
  <ContainerWithVeryLongNameThatExceedsReasonableLineLengths>
    <ChildElementWithLongName
      AttributeWithVeryLongName="Long attribute value here"
    /><AnotherChildElementWithLongName
      AnotherAttributeWithVeryLongName="Another long attribute value that should cause wrapping"
    />
  </ContainerWithVeryLongNameThatExceedsReasonableLineLengths>

  <!-- Test with nested non-self-closing elements that have long content -->
  <ContainerWithVeryLongNameThatExceedsReasonableLineLengths>
    <ChildElementWithLongName
      AttributeWithVeryLongName="Long attribute value here"
    >
      Foo bar baz
    </ChildElementWithLongName><AnotherChildElementWithLongName
      AnotherAttributeWithVeryLongName="Another long attribute value that should cause wrapping"
    >
      More content here
    </AnotherChildElementWithLongName>
  </ContainerWithVeryLongNameThatExceedsReasonableLineLengths>
</Root>

`;
